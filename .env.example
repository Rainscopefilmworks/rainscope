# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Project ID: https://www.sanity.io/manage → your project → Project ID

SANITY_PROJECT_ID=
SANITY_DATASET=production

# Only needed for seeding (scripts/seed-sanity.js). Create at sanity.io/manage → API → Tokens (Editor).
SANITY_TOKEN=

# Optional: one-time setup for Sanity → Cloudflare auto-rebuild (npm run setup:sanity-webhook)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=023f3f4e2494ed1ce69bdfcc0cf5e52e
# CF_PAGES_PROJECT=rainscope-site
# CF_PAGES_BRANCH=main
# SANITY_MANAGEMENT_TOKEN=  # needs webhooks write; or use `npx sanity login` in studio/
