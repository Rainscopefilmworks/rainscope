{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "rainscope-square-proxy",
  "main": "worker.js",
  "compatibility_date": "2026-06-11",
  "workers_dev": true,
  "vars": {
    "CORS_ORIGIN": "https://rainscope.ca,https://www.rainscope.ca,https://rainscopefilmworks.com,https://www.rainscopefilmworks.com",
    "ALLOW_PAGES_PREVIEW": "true",
    "ALLOW_WORKERS_DEV": "true",
    "ALLOW_LOCALHOST": "true",
    "SQUARE_API_BASE": "https://connect.squareup.com",
    "SQUARE_VERSION": "2025-01-22"
  }
}
